# ==============================================================================
# PolicyPilot Environment Configuration Template
# ==============================================================================
# Copy this file to `.env` and fill in the required keys.
# By default, the application runs offline using local embeddings and a mock LLM.

# ------------------------------------------------------------------------------
# 1. LLM Model Provider Settings
# ------------------------------------------------------------------------------
# Choose one of: 'mock', 'ollama', 'openai', 'gemini'
LLM_PROVIDER=mock

# Local Ollama Config (Use if LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI API Config (Use if LLM_PROVIDER=openai)
# Obtain your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API Config (Use if LLM_PROVIDER=gemini)
# Obtain your key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ------------------------------------------------------------------------------
# 2. RAG Chunking & Retrieval Parameters
# ------------------------------------------------------------------------------
# Text splitting parameters for document ingestion
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Min score threshold for hybrid retrieval (0.0 to 1.0)
# Below this, queries are flagged as "out-of-scope" to prevent hallucinations.
CONFIDENCE_THRESHOLD=0.35

# Linear combination weights for hybrid retriever. Must sum to 1.0.
HYBRID_SEMANTIC_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3

# ------------------------------------------------------------------------------
# 3. Directory Paths (Relative to Workspace Root)
# ------------------------------------------------------------------------------
DATA_DIR=data
DB_DIR=data/chromadb
POLICIES_DIR=data/policies
EVAL_QA_PATH=data/eval_qa.json
